        {
          "name": "Mutation - Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "    var jsonData = pm.response.json();",
                  "    if (jsonData.data && jsonData.data.register && jsonData.data.register.token) {",
                  "        pm.environment.set('token', jsonData.data.register.token);",
                  "        console.log('Nouvel utilisateur créé et token sauvegardé');",
                  "    }",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json",
                "type": "text"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"query\": \"mutation { register(email: \\\"newuser@example.com\\\", password: \\\"password123\\\", name: \\\"Jane Doe\\\") { token user { id email name roles } } }\"\n}"
            },
            "url": {
              "raw": "http://localhost:3000/graphql",
              "protocol": "http",
              "host": [
                "localhost"
              ],
              "port": "3000",
              "path": [
                "graphql"
              ]
            },
            "description": "Enregistrer un nouvel utilisateur"
          },
          "response": []
        },
